#!/bin/sh
# Auto-bump the in-game version to 0.1.<total commit count> on every commit, so the version shown on the
# title screen / HUD tracks how many commits the project has. The commit being made is (HEAD count + 1).
count=$(git rev-list --count HEAD 2>/dev/null || echo 0)
build=$((count + 1))
ini="Config/DefaultGame.ini"
new="ProjectVersion=0.1.$build"

[ -f "$ini" ] || exit 0

if grep -q '^ProjectVersion=' "$ini"; then
	tmp="$ini.verbump.tmp"
	sed "s/^ProjectVersion=.*/$new/" "$ini" > "$tmp" && mv "$tmp" "$ini"
else
	printf '%s\n' "$new" >> "$ini"
fi

git add "$ini"
